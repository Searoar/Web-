e471-81c2-4e9a-bd6d-b80930c28a0c", "last_modified": null, "metadata_modified": "2022-01-05T14:28:17.627429", "mimetype": null, "mimetype_inner": null, "name": "National dataset in CSV", "package_id": "ff93ffc1-6656-47d8-9155-85ea0b8f2251", "position": 2, "resource-type": "data-link", "resource_type": null, "size": null, "state": "active", "url": "https://naptan.api.dft.gov.uk/v1/access-nodes?dataFormat=csv", "url_type": null}, {"cache_last_updated": null, "cache_url": null, "created": "2022-01-05T14:27:55.558202", "datafile-date": "2022-01-05", "description": null, "format": "XML", "hash": "", "id": "98ce934c-1d9f-4443-bc58-59bf4d9f3b5c", "last_modified": null, "metadata_modified": "2022-01-05T14:27:55.541727", "mimetype": null, "mimetype_inner": null, "name": "National dataset in XML", "package_id": "ff93ffc1-6656-47d8-9155-85ea0b8f2251", "position": 3, "resource-type": "data-link", "resource_type": null, "size": null, "state": "active", "url": "https://naptan.api.dft.gov.uk/v1/access-nodes?dataFormat=xml", "url_type": null}], "tags": [], "groups": [], "relationships_as_subject": [], "relationships_as_object": []}, {"codelist": "", "contact-email": "Naptan.nptg@dft.gov.uk", "contact-name": "NaPTAN and NPTG team", "contact-phone": "", "creator_user_id": "2e2295dd-055a-44ec-b2ba-eaf8eede13e8", "foi-email": "Naptan.nptg@dft.gov.uk", "foi-name": "", "foi-phone": "", "foi-web": "", "id": "3b1766bf-04a3-44f5-bea9-5c74cf002e1d", "isopen": true, "licence-custom": "", "license_id": "uk-ogl", "license_title": "UK Open Government Licence (OGL)", "license_url": "http://reference.data.gov.uk/id/open-government-licence", "metadata_created": "2010-03-19T17:59:30.132821", "metadata_modified": "2022-08-23T13:21:36.959546", "name": "nptg", "notes": "This is the Government data catalogue page for NPTG. Use this link to visit the actual website for NPTG: https://beta-naptan.dft.gov.uk/\r\n\r\nNPTG a database of localities (cities, towns, villages and other settlements) in Great Britain.  It provides a common frame of reference for the National Public Access Nodes (NaPTAN) schema. \r\nThe appropriate naming and geospatial location of towns and places is vital for providing effective place and stop finding in on-line journey planners and other passenger information systems. Names are those that would be used by the people that reside or work in that place; the geospatial location is selected to optimise journey planning and other passenger information usage.\r\nThe NPTG XML schema is used to distribute topographic data from the NPTG database to the local Administrative Areas who administer NaPTAN data, as well as other downstream Public Transport Information systems such as journey planners.", "num_resources": 3, "num_tags": 0, "organization": {"id": "e4900b3b-a7f8-447a-bd5e-43735f8f1b4a", "name": "department-for-transport", "title": "Department for Transport", "type": "organization", "description": "We work with our agencies and partners to support the transport network that helps the UK\u2019s businesses and gets people and goods travelling around the country. We plan and invest in transport infrastructure to keep the UK on the move.\r\n\r\nDFT is a ministerial department, supported by 22 agencies and public bodies.\r\n\r\nhttps://www.gov.uk/government/organisations/department-for-transport\r\n", "image_url": "", "created": "2012-06-27T14:48:39.978928", "is_organization": true, "approval_status": "pending", "state": "active"}, "owner_org": "e4900b3b-a7f8-447a-bd5e-43735f8f1b4a", "private": false, "schema-vocabulary": "", "state": "active", "theme-primary": "transport", "title": "National Public Transport Gazetteer (NPTG)", "type": "dataset", "url": null, "version": null, "resources": [{"cache_last_updated": null, "cache_url": null, "datafile-date": "2022-08-23", "description": null, "format": "HTML", "id": "0993ea97-99fc-4b36-bac2-4bf2d7e7a314", "last_modified": null, "metadata_modified": "2022-08-23T11:22:41.174855", "mimetype": null, "mimetype